rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function callerUserExists() {
      return isSignedIn() && exists(userPath(request.auth.uid));
    }

    function callerUser() {
      return get(userPath(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return callerUserExists() && callerUser().role == 'super_admin';
    }

    function isAdmin() {
      return isSuperAdmin()
        || (callerUserExists() && callerUser().role == 'admin');
    }

    function isApproved() {
      return isAdmin() || (callerUserExists() && callerUser().approved == true);
    }

    function callerHasTenant() {
      return callerUserExists()
        && callerUser().tenantId is string
        && callerUser().tenantId != '';
    }

    function sameTenantResource() {
      return isSuperAdmin()
        || !callerHasTenant()
        || resource.data.tenantId == callerUser().tenantId;
    }

    function sameTenantRequest() {
      return isSuperAdmin()
        || !callerHasTenant()
        || request.resource.data.tenantId == callerUser().tenantId;
    }

    function sameTenantCreate() {
      return sameTenantRequest();
    }

    function sameTenantUpdate() {
      return sameTenantRequest() && sameTenantResource();
    }

    function isStaffRole() {
      return isApproved()
        && callerUser().role in [
          'teacher',
          'staff',
          'non_teaching_staff',
          'general_staff'
        ];
    }

    function isTeacher() {
      return isApproved() && callerUser().role == 'teacher';
    }

    function canTakeStudentAttendance() {
      return isAdmin()
        || (isApproved() && callerUser().canTakeStudentAttendance == true);
    }

    function canTakeStaffAttendance() {
      return isAdmin()
        || (isApproved() && callerUser().canTakeStaffAttendance == true);
    }

    function isAssignedToClassDoc(classDocId) {
      return isApproved()
        && classDocId is string
        && exists(/databases/$(database)/documents/classes/$(classDocId))
        && (
          get(/databases/$(database)/documents/classes/$(classDocId)).data.teacherId == request.auth.uid
          || (
            get(/databases/$(database)/documents/classes/$(classDocId)).data.assignedStaffUids is list
            && request.auth.uid in get(/databases/$(database)/documents/classes/$(classDocId)).data.assignedStaffUids
          )
        );
    }

    function isOwnStaffDoc() {
      return isSignedIn()
        && resource.data.userUid == request.auth.uid;
    }

    function wardIdFor(studentId) {
      return request.auth.uid + "_" + studentId;
    }

    function isParentOfStudent(studentId) {
      return isSignedIn()
        && studentId is string
        && exists(/databases/$(database)/documents/wards/$(wardIdFor(studentId)));
    }

    function isWritingOwnStaffAttendance() {
      return isStaffRole()
        && request.resource.data.subjectType == 'staff'
        && request.resource.data.subjectId is string
        && exists(/databases/$(database)/documents/staff/$(request.resource.data.subjectId))
        && get(/databases/$(database)/documents/staff/$(request.resource.data.subjectId)).data.userUid == request.auth.uid;
    }

    function isReadingOwnStaffAttendance() {
      return isStaffRole()
        && resource.data.subjectType == 'staff'
        && resource.data.subjectId is string
        && exists(/databases/$(database)/documents/staff/$(resource.data.subjectId))
        && get(/databases/$(database)/documents/staff/$(resource.data.subjectId)).data.userUid == request.auth.uid;
    }

    function isReadingWardAttendance() {
      return isSignedIn()
        && (
          (
            resource.data.keys().hasAll(['subjectType', 'subjectId'])
            && resource.data.subjectType == 'student'
            && resource.data.subjectId is string
            && isParentOfStudent(resource.data.subjectId)
          )
          || (
            resource.data.keys().hasAny(['studentId'])
            && resource.data.studentId is string
            && isParentOfStudent(resource.data.studentId)
          )
        );
    }

    function validAttendanceShape() {
      return request.resource.data.date is string
        && request.resource.data.date.size() == 10
        && request.resource.data.type in ['in', 'out']
        && request.resource.data.method in ['qr', 'fingerprint', 'face', 'manual']
        && (
          !(request.resource.data.keys().hasAny(['status']))
          || request.resource.data.status in ['present', 'absent', 'late', 'excused']
        )
        && (
          !(request.resource.data.keys().hasAny(['subjectType']))
          || request.resource.data.subjectType in ['student', 'staff']
        )
        && (
          !(request.resource.data.keys().hasAny(['subjectId']))
          || request.resource.data.subjectId is string
        )
        && (
          !(request.resource.data.keys().hasAny(['studentId']))
          || request.resource.data.studentId is string
        )
        && (
          !(request.resource.data.keys().hasAny(['classId']))
          || request.resource.data.classId is string
        )
        && (
          !(request.resource.data.keys().hasAny(['classDocId']))
          || request.resource.data.classDocId is string
        );
    }

    function attendanceUsesGeofenceBypass() {
      return request.resource.data.keys().hasAny(['location'])
        && request.resource.data.location is map
        && request.resource.data.location.geofencingBypassed == true;
    }


    // -------------------- TENANTS --------------------
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin()
        || (
          isSignedIn()
          && callerUserExists()
          && callerUser().tenantId == tenantId
        );

      allow create, update: if isSuperAdmin()
        && request.resource.data.name is string
        && request.resource.data.type in ['school', 'institution', 'company']
        && request.resource.data.status in ['active', 'trial', 'suspended'];

      allow delete: if isSuperAdmin();
    }
    // -------------------- TENANT INVITES --------------------
    match /tenantInvites/{code} {
      allow get: if resource.data.active == true
        || isSuperAdmin()
        || (callerHasTenant() && resource.data.tenantId == callerUser().tenantId);

      allow list: if isSuperAdmin();

      allow create, update: if isSuperAdmin()
        && request.resource.data.code == code
        && request.resource.data.tenantId is string
        && request.resource.data.tenantName is string
        && request.resource.data.tenantType in ['school', 'institution', 'company']
        && request.resource.data.active is bool;

      allow delete: if isSuperAdmin();
    }

    // -------------------- USERS --------------------
    match /users/{uid} {
      allow create: if isSignedIn()
        && (
          (
            request.auth.uid == uid
            && (
              !(request.resource.data.tenantId is string)
              || request.resource.data.tenantId == ''
              || (
                request.resource.data.tenantInviteCode is string
                && exists(/databases/$(database)/documents/tenantInvites/$(request.resource.data.tenantInviteCode))
                && get(/databases/$(database)/documents/tenantInvites/$(request.resource.data.tenantInviteCode)).data.active == true
                && get(/databases/$(database)/documents/tenantInvites/$(request.resource.data.tenantInviteCode)).data.tenantId == request.resource.data.tenantId
                && get(/databases/$(database)/documents/tenantInvites/$(request.resource.data.tenantInviteCode)).data.tenantName == request.resource.data.tenantName
                && get(/databases/$(database)/documents/tenantInvites/$(request.resource.data.tenantInviteCode)).data.tenantType == request.resource.data.tenantType
              )
            )
          )
          || (isAdmin() && sameTenantCreate())
        );

      allow get: if isSignedIn()
        && (request.auth.uid == uid || (isAdmin() && sameTenantResource()));

      allow list: if isAdmin() && sameTenantResource();

      allow update: if isSignedIn()
        && (
          (isAdmin() && sameTenantUpdate())
          || (
            request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'role',
              'approved',
              'canTakeStaffAttendance',
              'canTakeStudentAttendance',
              'tenantId',
              'tenantName',
              'tenantType',
              'tenantInviteCode'
            ])
          )
        );

      allow delete: if isAdmin()
        && sameTenantResource()
        && resource.data.role != 'admin'
        && request.auth.uid != uid;
    }

    // -------------------- CLASSES --------------------
    match /classes/{classId} {
      allow read: if isApproved() && sameTenantResource();

      allow create: if isAdmin()
        && sameTenantCreate()
        && request.resource.data.name is string
        && request.resource.data.classId is string
        && (!(request.resource.data.keys().hasAny(['teacherId'])) || request.resource.data.teacherId is string)
        && (!(request.resource.data.keys().hasAny(['assignedStaffUids'])) || request.resource.data.assignedStaffUids is list);

      allow update: if isAdmin()
        && sameTenantUpdate()
        && request.resource.data.name is string
        && request.resource.data.classId is string
        && (!(request.resource.data.keys().hasAny(['teacherId'])) || request.resource.data.teacherId is string)
        && (!(request.resource.data.keys().hasAny(['assignedStaffUids'])) || request.resource.data.assignedStaffUids is list);

      allow delete: if isAdmin() && sameTenantResource();
    }

    // -------------------- STUDENTS --------------------
    match /students/{studentId} {
      allow get: if (isAdmin() && sameTenantResource())
        || isAssignedToClassDoc(resource.data.classDocId)
        || isParentOfStudent(studentId);
      allow list: if (isAdmin() && sameTenantResource())
        || isAssignedToClassDoc(resource.data.classDocId);

      allow create: if isAdmin()
        && sameTenantCreate()
        && request.resource.data.name is string
        && (!(request.resource.data.keys().hasAny(['classId'])) || request.resource.data.classId is string);

      allow update: if isAdmin()
        && sameTenantUpdate()
        && request.resource.data.name is string
        && (!(request.resource.data.keys().hasAny(['classId'])) || request.resource.data.classId is string);

      allow delete: if isAdmin() && sameTenantResource();
    }

    // -------------------- STAFF --------------------
    match /staff/{staffId} {
      allow get: if ((isAdmin() || canTakeStaffAttendance()) && sameTenantResource()) || isOwnStaffDoc();
      allow list: if ((isAdmin() || canTakeStaffAttendance()) && sameTenantResource()) || isOwnStaffDoc();

      allow create: if isAdmin()
        && sameTenantCreate()
        && request.resource.data.name is string
        && (!(request.resource.data.keys().hasAny(['email'])) || request.resource.data.email is string)
        && (!(request.resource.data.keys().hasAny(['staffId'])) || request.resource.data.staffId is string);

      allow update: if isAdmin()
        && sameTenantUpdate()
        && request.resource.data.name is string
        && (!(request.resource.data.keys().hasAny(['email'])) || request.resource.data.email is string)
        && (!(request.resource.data.keys().hasAny(['staffId'])) || request.resource.data.staffId is string);

      allow delete: if isAdmin() && sameTenantResource();
    }

    // -------------------- ATTENDANCE --------------------
    match /attendance/{recId} {
      allow get: if ((isAdmin() || canTakeStaffAttendance()) && sameTenantResource())
        || (resource.data.subjectType == 'student' && isAssignedToClassDoc(resource.data.classDocId))
        || isReadingOwnStaffAttendance()
        || isReadingWardAttendance();

      allow list: if ((isAdmin() || canTakeStaffAttendance()) && sameTenantResource())
        || (resource.data.subjectType == 'student' && isAssignedToClassDoc(resource.data.classDocId))
        || isReadingOwnStaffAttendance()
        || isReadingWardAttendance();

      allow create: if validAttendanceShape()
        && sameTenantCreate()
        && (
          isAdmin()
          || (request.resource.data.subjectType == 'student' && canTakeStudentAttendance())
          || (!attendanceUsesGeofenceBypass() && request.resource.data.subjectType == 'student' && isAssignedToClassDoc(request.resource.data.classDocId))
          || (request.resource.data.subjectType == 'staff' && canTakeStaffAttendance())
          || (!attendanceUsesGeofenceBypass() && isWritingOwnStaffAttendance())
        );

      allow update: if validAttendanceShape()
        && sameTenantUpdate()
        && (
          isAdmin()
          || (resource.data.subjectType == 'student' && canTakeStudentAttendance())
          || (!attendanceUsesGeofenceBypass() && resource.data.subjectType == 'student' && isAssignedToClassDoc(resource.data.classDocId) && request.resource.data.classDocId == resource.data.classDocId)
          || (resource.data.subjectType == 'staff' && canTakeStaffAttendance())
          || (!attendanceUsesGeofenceBypass() && isReadingOwnStaffAttendance() && request.resource.data.subjectType == resource.data.subjectType && request.resource.data.subjectId == resource.data.subjectId)
        );

      allow delete: if isAdmin() && sameTenantResource();
    }

    // -------------------- TERMS --------------------
    match /terms/{termId} {
      allow read: if isApproved() && sameTenantResource();

      allow create: if isAdmin()
        && sameTenantCreate()
        && request.resource.data.name is string
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string;

      allow update: if isAdmin()
        && sameTenantUpdate()
        && request.resource.data.name is string
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string;

      allow delete: if isAdmin() && sameTenantResource();
    }

    // -------------------- ADMIN LOGS --------------------
    match /adminLogs/{logId} {
      allow create: if isApproved()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.targetType is string
        && request.resource.data.createdAt != null;

      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // -------------------- WEEKS --------------------
    match /weeks/{weekId} {
      allow read: if isApproved() && sameTenantResource();

      allow create: if isAdmin()
        && sameTenantCreate()
        && request.resource.data.termId is string
        && request.resource.data.weekNumber is int
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string;

      allow update: if isAdmin()
        && sameTenantUpdate()
        && request.resource.data.termId is string
        && request.resource.data.weekNumber is int
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string;

      allow delete: if isAdmin() && sameTenantResource();
    }

    // -------------------- SETTINGS --------------------
    match /settings/{docId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // -------------------- WARDS --------------------
    match /wards/{wardId} {
      allow get: if isAdmin()
        || (isSignedIn() && resource.data.parentUid == request.auth.uid);

      allow list: if isAdmin()
        || (isSignedIn() && resource.data.parentUid == request.auth.uid);

      allow create, update, delete: if isAdmin();
    }

    // -------------------- LEGACY STAFF ATTENDANCE --------------------
    match /staffAttendance/{recId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // -------------------- DEFAULT: DENY --------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}





